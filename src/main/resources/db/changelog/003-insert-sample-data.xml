<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003" author="siarhei" context="dev">
        <!-- Sample Business -->
        <insert tableName="businesses">
            <column name="id" valueNumeric="1"/>
            <column name="name" value="Coffee House"/>
            <column name="owner_telegram_id" valueNumeric="472317443"/>
            <column name="plan" value="pro"/>
            <column name="timezone" value="Europe/Minsk"/>
            <column name="active" valueBoolean="true"/>
        </insert>

        <!-- Sample Coupons -->
        <insert tableName="coupons">
            <column name="id" valueNumeric="1"/>
            <column name="business_id" valueNumeric="1"/>
            <column name="name" value="Free Coffee"/>
            <column name="stamp_target" valueNumeric="9"/>
            <column name="reward_description" value="Получи бесплатный кофе после 9 покупок"/>
            <column name="validity_days" valueNumeric="30"/>
            <column name="active" valueBoolean="true"/>
        </insert>

        <insert tableName="coupons">
            <column name="id" valueNumeric="2"/>
            <column name="business_id" valueNumeric="1"/>
            <column name="name" value="20% Discount"/>
            <column name="stamp_target" valueNumeric="5"/>
            <column name="reward_description" value="Скидка 20% на следующий заказ"/>
            <column name="validity_days" valueNumeric="30"/>
            <column name="active" valueBoolean="true"/>
        </insert>

        <!-- Sample Staff Member -->
        <insert tableName="staff_members">
            <column name="id" valueNumeric="1"/>
            <column name="business_id" valueNumeric="1"/>
            <column name="name" value="Admin"/>
            <column name="role" value="admin"/>
            <column name="active" valueBoolean="true"/>
        </insert>
    </changeSet>

</databaseChangeLog>
